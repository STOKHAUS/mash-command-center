.spot-event{color:rgba(255,255,255,.6) !important}
.tab{color:#888 !important}
.tab.active{color:#fff !important}
.footer{color:#666 !important}
.info-strip .lbl,.hero-lbl{color:#666 !important}
.ath-sub{color:#666 !important}
</style>
