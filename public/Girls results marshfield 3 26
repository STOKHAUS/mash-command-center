<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--red:#cc0000;--dk:#0a0a0a;--card:#131313;--bdr:rgba(255,255,255,.06);--gold:#d4a843;--grn:#22c55e;--blu:#4a9eff;--mut:#666;--surface:#111}
body{font-family:'Barlow',sans-serif !important;background:var(--dk) !important;background-color:#0a0a0a !important;color:#fff !important;min-height:100vh;-webkit-font-smoothing:antialiased}
a{color:var(--red) !important;text-decoration:none !important}a:hover{text-decoration:underline !important}

/* TOPBAR */
.topbar{background:linear-gradient(135deg,#1a0000,var(--dk)) !important;border-bottom:2px solid var(--red) !important;padding:14px 16px;text-align:center;position:sticky;top:0;z-index:100}
.brand{font-family:'Oswald',sans-serif !important;font-weight:800;font-size:1.1rem;letter-spacing:.12em;text-transform:uppercase;color:#fff !important}
.brand span{color:var(--red) !important}
.meet-title{font-family:'Oswald',sans-serif !important;font-weight:700;font-size:.75rem;color:rgba(255,255,255,.45) !important;text-transform:uppercase;letter-spacing:.08em;margin-top:2px}

/* INFO STRIP */
.info-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--bdr) !important}
.info-strip>div{background:var(--surface) !important;background-color:#111 !important;padding:12px 8px;text-align:center}
.info-strip .val{font-family:'Oswald',sans-serif !important;font-weight:800;font-size:1.15rem;line-height:1;color:#fff !important}
.info-strip .lbl{font-size:.5rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--mut) !important;margin-top:3px}

/* HERO STAT ROW */
.hero-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--bdr) !important;margin-top:1px}
.hero-row>div{background:var(--surface) !important;background-color:#111 !important;padding:16px 10px;text-align:center}
.hero-val{font-family:'Oswald',sans-serif !important;font-weight:800;font-size:2rem;line-height:1;color:#fff !important}
.hero-lbl{font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--mut) !important;margin-top:4px}

/* SECTION */
.sec{padding:0 16px 16px;max-width:720px;margin:0 auto}
.label{font-size:.55rem;font-weight:800;text-transform:uppercase;letter-spacing:.2em;color:var(--red) !important;margin:20px 0 8px;display:flex;align-items:center;gap:8px}
.label::after{content:'';flex:1;height:1px;background:rgba(204,0,0,.25) !important}

/* SPOTLIGHT CARD */
.spotlight{background:linear-gradient(135deg,rgba(204,0,0,.12),rgba(204,0,0,.03)) !important;border:1px solid rgba(204,0,0,.3) !important;border-left:4px solid var(--red) !important;padding:16px;margin-bottom:10px;position:relative;overflow:hidden}
.spotlight::before{content:'🥇';position:absolute;top:10px;right:14px;font-size:1.8rem;opacity:.6}
.spot-name{font-family:'Oswald',sans-serif !important;font-weight:800;font-size:1.3rem;text-transform:uppercase;line-height:1;color:#fff !important}
.spot-meta{font-size:.68rem;color:rgba(255,255,255,.45) !important;font-weight:600;margin-top:2px}
.spot-mark{font-family:'Oswald',sans-serif !important;font-weight:800;font-size:1.6rem;color:var(--gold) !important;margin-top:6px}
.spot-event{font-size:.72rem;color:rgba(255,255,255,.6) !important;font-weight:600}
.spot-note{font-size:.72rem;color:rgba(255,255,255,.4) !important;margin-top:6px;font-style:italic;line-height:1.4}

/* RESULT ROW */
.result{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--card) !important;background-color:#131313 !important;border:1px solid var(--bdr) !important;margin-bottom:4px;transition:background .15s}
.result:hover{background:rgba(255,255,255,.03) !important}
.result-place{font-family:'Oswald',sans-serif !important;font-weight:800;font-size:1rem;min-width:32px;text-align:center;color:rgba(255,255,255,.35) !important}
.result-place.top5{color:var(--gold) !important}
.result-place.top10{color:var(--grn) !important}
.result-info{flex:1;min-width:0}
.result-name{font-weight:700;font-size:.85rem;line-height:1.2;color:#fff !important}
.result-event{font-size:.68rem;color:rgba(255,255,255,.4) !important;font-weight:600}
.result-mark{font-family:'Oswald',sans-serif !important;font-weight:700;font-size:1rem;color:#fff !important;text-align:right;white-space:nowrap}
.badge{display:inline-block;font-size:.48rem;font-weight:800;text-transform:uppercase;letter-spacing:.04em;padding:2px 6px;margin-left:6px;vertical-align:middle}
.badge-v{background:rgba(204,0,0,.2) !important;color:#ff4444 !important;border:1px solid rgba(204,0,0,.3) !important}
.badge-jv{background:rgba(255,255,255,.05) !important;color:#888 !important;border:1px solid rgba(255,255,255,.08) !important}
.badge-gold{background:rgba(212,168,67,.2) !important;color:var(--gold) !important;border:1px solid rgba(212,168,67,.3) !important}
.badge-pr{background:rgba(34,197,94,.15) !important;color:var(--grn) !important;border:1px solid rgba(34,197,94,.3) !important}
.badge-win{background:rgba(204,0,0,.25) !important;color:#ff4444 !important;border:1px solid rgba(204,0,0,.4) !important;font-size:.52rem}

/* ATHLETE CARD (compact) */
.ath-card{background:var(--card) !important;background-color:#131313 !important;border:1px solid var(--bdr) !important;border-left:3px solid var(--red) !important;margin-bottom:6px;overflow:hidden}
.ath-header{display:flex;justify-content:space-between;align-items:center;padding:10px 12px;cursor:pointer}
.ath-header:hover{background:rgba(255,255,255,.02) !important}
.ath-name{font-family:'Oswald',sans-serif !important;font-weight:700;font-size:.95rem;text-transform:uppercase;color:#fff !important}
.ath-sub{font-size:.62rem;color:var(--mut) !important;font-weight:600}
.ath-count{font-size:.58rem;font-weight:800;background:rgba(204,0,0,.15) !important;color:#ff4444 !important;padding:2px 8px;text-transform:uppercase}
.ath-body{padding:0 12px 10px;border-top:1px solid var(--bdr) !important}
.ath-evt{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.03) !important}
.ath-evt:last-child{border-bottom:none !important}
.ath-evt-place{font-family:'Oswald',sans-serif !important;font-weight:700;font-size:.82rem;color:var(--gold) !important;min-width:28px;text-align:right}
.ath-evt-name{font-weight:600;font-size:.78rem;flex:1;color:#fff !important}
.ath-evt-mark{font-family:'Oswald',sans-serif !important;font-weight:600;font-size:.82rem;color:rgba(255,255,255,.7) !important}

/* GAP CARD */
.gap-card{background:rgba(255,68,68,.04) !important;border:1px solid rgba(204,0,0,.2) !important;border-left:3px solid var(--red) !important;padding:12px 14px;margin-bottom:6px}
.gap-title{font-weight:700;font-size:.82rem;color:#ff4444 !important}
.gap-detail{font-size:.72rem;color:rgba(255,255,255,.4) !important;margin-top:3px;line-height:1.4}

/* TOGGLE TABS */
.tabs{display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap}
.tab{padding:6px 14px;background:rgba(255,255,255,.04) !important;color:#888 !important;border:1px solid rgba(255,255,255,.08) !important;font-weight:700;font-size:.6rem;text-transform:uppercase;letter-spacing:.06em;cursor:pointer;font-family:inherit;transition:all .15s}
.tab.active{background:var(--red) !important;background-color:#cc0000 !important;color:#fff !important;border-color:var(--red) !important}

/* FOOTER */
.footer{text-align:center;padding:24px 16px;font-size:.58rem;color:var(--mut) !important;border-top:1px solid var(--bdr) !important;margin-top:24px}

/* RESPONSIVE */
@media(max-width:600px){
  .info-strip{grid-template-columns:repeat(2,1fr)}
  .hero-row{grid-template-columns:repeat(3,1fr)}
  .hero-val{font-size:1.6rem}
  .info-strip .val{font-size:1rem}
}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.sec>*{animation:fadeUp .4s ease both}
.sec>*:nth-child(1){animation-delay:.05s}
.sec>*:nth-child(2){animation-delay:.1s}
.sec>*:nth-child(3){animation-delay:.15s}
.sec>*:nth-child(4){animation-delay:.2s}
.sec>*:nth-child(5){animation-delay:.25s}

/* ═══ SQUARESPACE NUCLEAR OVERRIDE ═══ */
/* Squarespace injects styles that force black text. Override everything. */
body,div,span,p,h1,h2,h3,h4,h5,h6,li,td,th,label,
input,select,textarea,button,a{color:#fff !important}
.meet-title,.spot-meta,.spot-note,.result-event,
